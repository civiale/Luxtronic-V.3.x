{
  "common": {
    "name": "luxtronik2ws",
    "version": "0.1.0",
    "news": {
      "0.1.0": {
        "en": "Initial release - WebSocket support for Luxtronik v3.81+",
        "de": "Erstveröffentlichung - WebSocket Unterstützung für Luxtronik v3.81+"
      }
    },
    "title": "Luxtronik 2.1 WebSocket",
    "titleLang": {
      "en": "Luxtronik 2.1 WebSocket",
      "de": "Luxtronik 2.1 WebSocket"
    },
    "desc": {
      "en": "Connects ioBroker to Alpha Innotec / Luxtronik 2.1 heat pumps via WebSocket protocol (Lux_WS). Supports firmware V3.81 and newer. Automatically reads all available data points such as temperatures, operating hours, energy monitor and system status.",
      "de": "Verbindet ioBroker mit Alpha Innotec / Luxtronik 2.1 Wärmepumpen via WebSocket-Protokoll (Lux_WS). Unterstützt Firmware V3.81 und neuer. Liest automatisch alle verfügbaren Datenpunkte wie Temperaturen, Betriebsstunden, Energiemonitor und Anlagenstatus."
    },
    "authors": [
      "alessandrocivi <github.com/civiale>"
    ],
    "keywords": [
      "luxtronik",
      "luxtronik2",
      "alpha innotec",
      "wärmepumpe",
      "heatpump",
      "websocket",
      "novelan",
      "heating"
    ],
    "license": "MIT",
    "type": "climate-control",
    "icon": "admin/luxtronik.png",
    "enabled": true,
    "readme": "https://github.com/civiale/iobroker.luxtronik2ws/blob/main/README.md",
    "loglevel": "info",
    "mode": "daemon",
    "platform": "Javascript/Node.js",
    "adminUI": {
      "config": "json"
    },
    "connectionType": "local",
    "dataSource": "push",
    "tier": 2,
    "version": "0.1.0",
    "licenseUrl": "https://github.com/civiale/iobroker.luxtronik2ws/blob/main/LICENSE",
    "extIcon": "https://raw.githubusercontent.com/civiale/iobroker.luxtronik2ws/main/admin/luxtronik.png",
    "logTransporter": false,
    "compact": false
  },
  "native": {
    "host": "",
    "port": 8214,
    "password": "999999",
    "pollInterval": 30,
    "reconnectInterval": 60
  },
  "objects": [],
  "instanceObjects": [
    {
      "_id": "info",
      "type": "channel",
      "common": {
        "name": "Information"
      },
      "native": {}
    },
    {
      "_id": "info.connection",
      "type": "state",
      "common": {
        "name": {
          "en": "Connection status",
          "de": "Verbindungsstatus"
        },
        "type": "boolean",
        "role": "indicator.connected",
        "read": true,
        "write": false,
        "def": false
      },
      "native": {}
    }
  ]
}
